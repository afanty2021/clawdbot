{
  "id": "serper",
  "name": "Serper Plugin",
  "description": "Serper.dev Search API provider - Real-time Google Search results API",
  "version": "1.0.0",
  "type": "web-search-provider",
  "author": "OpenClaw Community",
  "license": "MIT",
  "entry": "index.ts",
  "capabilities": {
    "webSearch": true
  },
  "credentials": {
    "type": "api_key",
    "envVar": "SERPER_API_KEY",
    "configPath": "plugins.entries.serper.config.webSearch.apiKey"
  },
  "externalLinks": {
    "signup": "https://serper.dev",
    "docs": "https://serper.dev/api-reference",
    "pricing": "https://serper.dev/pricing"
  },
  "uiHints": {
    "webSearch.apiKey": {
      "label": "Serper API Key",
      "help": "Serper.dev API key for Google Search results (fallback: SERPER_API_KEY env var).",
      "sensitive": true
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "webSearch": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "apiKey": {
            "type": ["string", "object"]
          },
          "baseUrl": {
            "type": "string"
          }
        }
      }
    }
  }
}
